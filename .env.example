# Aura AI Environment Variables Example
# Copy this file to .env and fill in the values

# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# For local development: Leave blank to use mongodb://localhost:27017/ChatBot_AI
# For production/Vercel: Use your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ChatBot_AI?retryWrites=true&w=majority
